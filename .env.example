# === Verilənlər bazası (MySQL / MariaDB) ===
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=aderp
DB_PASSWORD=change-me
DB_NAME=admedia_erp

# === JWT auth ===
# Güclü təsadüfi dəyər yarat:  openssl rand -hex 32
AUTH_SECRET=replace-with-a-64-char-hex-secret

# === Mühit ===
NODE_ENV=production

# Cookie Secure bayrağı — YALNIZ HTTPS-də "true" et.
# HTTP-də (IP ilə) true olsa, sessiya cookie-si saxlanmır → login döngüsü.
COOKIE_SECURE=false
